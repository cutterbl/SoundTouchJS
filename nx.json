{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/tsconfig.spec.json"
    ]
  },
  "neverConnectToCloud": true,
  "daemon": true,
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json"
        }
      }
    },
    {
      "plugin": "@nx/vite/plugin",
      "options": {
        "buildTargetName": "build",
        "devTargetName": "dev",
        "previewTargetName": "preview",
        "serveStaticTargetName": "serve-static",
        "typecheckTargetName": "typecheck"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": true
    }
  },
  "release": {
    "conventionalCommits": {
      "types": {
        "feat": {
          "semverBump": "minor"
        },
        "fix": {
          "semverBump": "patch"
        },
        "perf": {
          "semverBump": "patch"
        },
        "ci": {
          "semverBump": "patch"
        },
        "chore": {
          "semverBump": "patch"
        },
        "build": {
          "semverBump": "patch"
        },
        "refactor": {
          "semverBump": "patch"
        },
        "docs": {
          "semverBump": "none"
        },
        "style": {
          "semverBump": "none"
        },
        "test": {
          "semverBump": "none"
        }
      }
    },
    "git": {
      "commit": true,
      "commitMessage": "chore(release): publish {version}",
      "tag": true,
      "tagMessage": "Release {version}"
    },
    "version": {
      "conventionalCommits": true,
      "preVersionCommand": "pnpm dlx nx run-many -t build",
      "fallbackCurrentVersionResolver": "disk"
    },
    "projects": ["@soundtouchjs/core", "@soundtouchjs/audio-worklet"],
    "changelog": {
      "automaticFromRef": false,
      "createRelease": true,
      "workspaceChangelog": {
        "createRelease": "github",
        "file": "CHANGELOG.md"
      },
      "projectChangelogs": {
        "createRelease": "github"
      }
    }
  }
}
