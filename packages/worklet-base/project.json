{
  "name": "@soundtouchjs/worklet-base",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/.dist"],
      "cache": true,
      "options": {
        "cwd": "{projectRoot}",
        "command": "tsc --build tsconfig.lib.json",
        "parallel": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "tsc --build tsconfig.lib.json --emitDeclarationOnly"
      },
      "outputs": [
        "{projectRoot}/.dist/**/*.d.ts",
        "{projectRoot}/.dist/**/*.d.ts.map",
        "{projectRoot}/.dist/tsconfig.tsbuildinfo"
      ],
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["{projectRoot}/src/**/*.ts"]
      }
    }
  }
}
