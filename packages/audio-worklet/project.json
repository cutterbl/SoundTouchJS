{
  "name": "audio-worklet",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["tsc --build tsconfig.lib.json", "vite build"],
        "parallel": false
      }
    }
  }
}
